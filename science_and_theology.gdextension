[configuration]
entry_symbol = "science_and_theology_library_init"
compatibility_minimum = "4.6"

[libraries]
windows.x86_64.debug = "bin/science_and_theology.dll"
windows.x86_64.release = "bin/science_and_theology.dll"
linux.x86_64.debug = "bin/libscience_and_theology.so"
linux.x86_64.release = "bin/libscience_and_theology.so"
macos.debug = "bin/libscience_and_theology.dylib"
macos.release = "bin/libscience_and_theology.dylib"