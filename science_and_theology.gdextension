[configuration]
entry_symbol = "science_and_theology_library_init"
compatibility_minimum = "4.6"

[libraries]
windows.debug.x86_64 = "res://bin/Debug/science_and_theology.dll"
windows.release.x86_64 = "res://bin/Release/science_and_theology.dll"
linux.debug.x86_64 = "res://bin/libscience_and_theology.so"
linux.release.x86_64 = "res://bin/libscience_and_theology.so"
macos.debug = "res://bin/libscience_and_theology.dylib"
macos.release = "res://bin/libscience_and_theology.dylib"
