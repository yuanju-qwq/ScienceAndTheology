# Simple cube for P1.5 testing.
# 8 vertices, 12 triangles, 24 unique vertex entries (for per-face normals).

v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

vn  0  0  1
vn  0  0 -1
vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0

# Front face (+Z)
f 1//1 2//1 3//1
f 1//1 3//1 4//1

# Back face (-Z)
f 5//2 6//2 7//2
f 5//2 7//2 8//2

# Right face (+X)
f 2//3 6//3 7//3
f 2//3 7//3 3//3

# Left face (-X)
f 1//4 5//4 8//4
f 1//4 8//4 4//4

# Top face (+Y)
f 4//5 3//5 7//5
f 4//5 7//5 8//5

# Bottom face (-Y)
f 1//6 2//6 6//6
f 1//6 6//6 5//6
