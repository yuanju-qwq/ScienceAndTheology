# Godot 4+ specific ignores
.godot/
/android/

# C++ build artifacts
build/
build-vs/
build_local/
bin/
build2/
bin/*.dll
bin/*.so
bin/*.dylib
bin/*.framework/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# Godot exports
builds/

# godot-cpp (fetched by CMake)
_builds/

# Self-built engine build artifacts
engine/build/
build-engine/
_deps/

# IDE files
.vs/
.idea/
*.user
*.suo
*.sln
*.vcxproj
*.vcxproj.filters

# Self-built engine: build logs
cmake-full.log
build-debug.log
build-*.log

# Self-built engine: pre-downloaded third-party archives.
# Regenerate via engine/cmake/download_third_party.ps1.
#engine/third_party/_downloads/

# Self-built engine: extracted third-party source.
# Regenerate by extracting archives from _downloads/.
engine/third_party/SDL-release-*/

# Temporary test directories
test-*/

# Self-built engine: runtime log files
logs/
*.log
engine_run*.log

